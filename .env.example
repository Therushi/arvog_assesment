# ---- Shared ----
NODE_ENV=development

# ---- Ports (host) ----
FRONTEND_PORT=4200
BACKEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379

# ---- PostgreSQL ----
POSTGRES_HOST=db
POSTGRES_DB=arvog
POSTGRES_USER=arvog
POSTGRES_PASSWORD=arvog_secret

# ---- Redis ----
REDIS_HOST=redis
REDIS_PASSWORD=

# ---- Backend ----
JWT_SECRET=change_me_in_real_env
API_PREFIX=/api/v1

# ---- Frontend ----
# URL the browser uses to reach the backend
API_BASE_URL=http://localhost:3000/api/v1
