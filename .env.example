# ---- Shared ----
NODE_ENV=development

# ---- Ports (host) ----
FRONTEND_PORT=4200
BACKEND_PORT=3000
MYSQL_PORT=3306
REDIS_PORT=6379

# ---- MySQL ----
MYSQL_HOST=db
MYSQL_DATABASE=arvog
MYSQL_USER=arvog
MYSQL_PASSWORD=arvog_secret
MYSQL_ROOT_PASSWORD=root_secret

# ---- Redis ----
REDIS_HOST=redis
REDIS_PASSWORD=

# ---- Backend ----
JWT_SECRET=change_me_in_real_env
JWT_EXPIRES_IN=1d
API_PREFIX=/api/v1

# ---- Frontend ----
# URL the browser uses to reach the backend
API_BASE_URL=http://localhost:3000/api/v1
